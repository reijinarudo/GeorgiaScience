---
// Base layout: header nav, footer with full org name, global styles.
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'GeorgiaScience.org',
  description = 'Advancing science education and scientific literacy across Georgia.',
} = Astro.props;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/resources', label: 'Resources' },
  { href: '/news', label: 'News' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: '/contact', label: 'Contact' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Source+Sans+3:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="wrap header-inner">
        <a href="/" class="brand">
          <img src="/galogonew.png" alt="" class="brand-logo" />
          <span>GeorgiaScience<span class="brand-dot">.org</span></span>
        </a>
        <nav aria-label="Primary">
          <ul class="nav-list">
            {nav.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <p class="footer-org">Georgia Citizens for Integrity and Science Education</p>
        <p class="footer-mission">
          Advancing science education and scientific literacy across Georgia.
        </p>
        <ul class="footer-links">
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>
    </footer>
    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--accent);
        color: var(--accent-ink);
        padding: 0.5rem 1rem;
        z-index: 100;
      }
      .skip-link:focus { left: 0; }
      .site-header {
        border-bottom: 1px solid var(--hairline);
        background: var(--surface);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 4rem;
        flex-wrap: wrap;
      }
      .brand {
        font-weight: 700;
        font-size: var(--step-1);
        text-decoration: none;
        letter-spacing: -0.01em;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .brand-logo { width: 36px; height: 36px; flex-shrink: 0; }
      .brand-dot { color: var(--accent); }
      .nav-list {
        display: flex;
        gap: 1.25rem;
        list-style: none;
        margin: 0;
        padding: 0;
        flex-wrap: wrap;
      }
      .nav-list a {
        text-decoration: none;
        color: var(--ink-soft);
        font-size: var(--step--1);
        font-weight: 500;
      }
      .nav-list a:hover { color: var(--ink); }
      .site-footer {
        margin-top: 4rem;
        border-top: 1px solid var(--hairline);
        background: var(--deep);
        color: var(--deep-ink);
        padding-block: 2.5rem;
      }
      .footer-org { font-weight: 700; margin: 0 0 0.25rem; }
      .footer-mission { margin: 0 0 1rem; color: var(--deep-ink); opacity: 0.85; }
      .footer-links {
        display: flex;
        gap: 1rem;
        list-style: none;
        margin: 0;
        padding: 0;
        flex-wrap: wrap;
      }
      .footer-links a { color: var(--deep-ink); font-size: var(--step--1); }
    </style>
  </body>
</html>
